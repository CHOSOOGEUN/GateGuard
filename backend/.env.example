# DB 설정
POSTGRES_USER=gateguard
POSTGRES_PASSWORD=gateguard1234
POSTGRES_DB=gateguard
DATABASE_URL=postgresql+asyncpg://gateguard:gateguard1234@db:5432/gateguard

# Redis 설정
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
